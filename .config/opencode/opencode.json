{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "bash": "ask"
  },
  "default_agent": "coworker",
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": false
    },
    "coworker": {
      "mode": "primary",
      "description": "Custom agent to act as a coworker",
      "prompt": "{file:~/.config/opencode/prompts/coworker.txt}",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
